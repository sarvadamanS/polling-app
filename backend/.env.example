# ── Local dev without Docker ──────────────────────────────────────────────────
# Uses SQLite — zero setup needed
# DATABASE_URL="file:./dev.db"

# ── Local dev WITH Docker (docker-compose spins up Postgres) ──────────────────
# Use this when running: docker-compose up
DATABASE_URL="postgresql://poll_user:poll_pass@127.0.0.1:5432/poll_db"
# ── Production (Supabase) ─────────────────────────────────────────────────────
# Paste your Supabase connection string (Session mode, port 5432)
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

SESSION_SECRET="change-me-super-secret-key-2024"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
